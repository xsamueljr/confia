---
---
<script src="@lib/contact-form.ts" />

<div class="mb-16">
  <h2 class="text-3xl font-bold text-blue-800 text-center mb-8">Contáctanos</h2>
  <form id="contact-form" class="max-w-lg mx-auto">
    <div class="mb-4">
      <label for="name" class="block text-blue-700 mb-2">Nombre</label>
      <input
        type="text"
        id="name"
        name="name"
        required
        minlength="3"
        maxlength="20"
        class="w-full px-3 py-2 border border-blue-300 rounded-lg focus:outline-none focus:border-blue-500"
      />
    </div>
    <div class="mb-4">
      <label for="email" class="block text-blue-700 mb-2">Email</label>
      <input
        type="email"
        id="email"
        name="email"
        required
        class="w-full px-3 py-2 border border-blue-300 rounded-lg focus:outline-none focus:border-blue-500"
      />
    </div>
    <div class="mb-4">
      <label for="message" class="block text-blue-700 mb-2">Mensaje</label>
      <textarea
        id="message"
        name="message"
        required
        minlength="1"
        maxlength="500"
        rows={4}
        class="w-full px-3 py-2 border border-blue-300 rounded-lg focus:outline-none focus:border-blue-500"
      ></textarea>
    </div>
    <button
      type="submit"
      class="w-full bg-blue-600 text-white py-2 rounded-lg hover:bg-blue-700 transition-colors duration-300"
    >
      Enviar Mensaje
    </button>
  </form>
</div>
